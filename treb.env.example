# Treb example environment
# Source this before running treb.pl, then override as needed.

export OWNER="mateu"
export ENGINE="Ollama"
export MODEL="kimi-k2.5:cloud"
export OLLAMA_URL="http://127.0.0.1:11434"
export IRC_SERVER="irc.perl.org"
export IRC_CHANNELS="#ai"
export IRC_NICKNAME="Treb"
export BOT_FILTER_NICKS="Bert"
export DB_FILE="/home/hunter/dev/treb/treb.sqlite"
export MAX_LINE_LENGTH="400"
export BUFFER_DELAY="1.5"
export LINE_DELAY="3"
export IDLE_PING="1800"

# Optional prompt extension appended after the mission file.
# export SYSTEM_PROMPT=""

# Optional explicit web search command support
export BRAVE_API_KEY=""
export MCP_TOOL_LOGGING="1"
export STORE_SYSTEM_ROWS="0"
export STORE_NON_SUBSTANTIVE_ROWS="0"
export STORE_EMPTY_RESPONSE_ROWS="0"

# Optional: only set if your selected engine actually requires an API key.
# export API_KEY=""
